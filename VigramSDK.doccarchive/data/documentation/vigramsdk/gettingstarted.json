isher<SinglePoint, Error> = ","    singlePointService.record(","        duration: 5, ","        updateInterval: 0.01, ","        with: CoordinateCorrection.Method.none","    )"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you need to use pedestrian or stationary dynamic state mode viDoc with SinglePoint measurements use this init"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Note","type":"text"}],"type":"strong"},{"type":"text","text":": This option available on 0.5.4 SDK version or up"}],"type":"paragraph"},{"code":["\/\/ Init without laser","let singlePointService: SinglePointRecordingService = ","    Vigram.singlePointRecordingService(","    gpsService: GPSService, ","    peripheral: Peripheral, ","    dynamicStateType: DynamicStateType",")","\/\/ Init with laser","let singlePointService: SinglePointRecordingService = ","Vigram.singlePointRecordingService(","    gpsService: gpsService, ","    laserService: laserService, ","    peripheral: peripheral, ","    dynamicStateType: .pedestrian",")"],"syntax":"swift","type":"codeListing"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/gettingstarted"]}],"references":{"doc://com.vigram.VigramSDK/documentation/VigramSDK/BluetoothService/disconnect()":{"title":"disconnect()","required":true,"url":"\/documentation\/vigramsdk\/bluetoothservice\/disconnect()","kind":"symbol","abstract":[{"text":"Disconnect to a current peripheral.","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"disconnect","kind":"identifier"},{"text":"()","kind":"text"}],"identifier":"doc:\/\/com.vigram.VigramSDK\/documentation\/VigramSDK\/BluetoothService\/disconnect()","type":"topic","role":"symbol"},"logo.png":{"type":"image","identifier":"logo.png","variants":[{"traits":["1x","light"],"url":"\/images\/logo.png"}],"alt":"Vigram logo."},"doc://com.vigram.VigramSDK/documentation/VigramSDK/GPSService":{"type":"topic","url"