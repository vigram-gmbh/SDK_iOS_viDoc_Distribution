{"sections":[],"hierarchy":{"paths":[["doc:\/\/com.vigram.VigramSDK\/documentation\/VigramSDK"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"modules":[{"name":"VigramSDK"}],"images":[{"type":"icon","identifier":"logo.png"}],"role":"article","title":"Use Peripheral Logger","roleHeading":"Article"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"","level":2,"type":"heading","text":""},{"inlineContent":[{"type":"text","text":"If you need use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.vigram.VigramSDK\/documentation\/VigramSDK\/PeripheralLogger"},{"text":" first create URL path for logger file.","type":"text"},{"type":"text","text":" "},{"text":"Example:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["var path: URL? \/\/ Path for logger file.","\/\/ For example let file = \"log.txt\"","let file = \"Filename\" + \".\" + \"file extension\" ","","let fileManager = FileManager.default","let directory = fileManager.urls(","    for: .documentDirectory, ","    in: .userDomainMask",")","","if directory.count != 0  {","    path = directory[0].appendingPathComponent(\"Name directory\")","    if let path = path?.path {","        if !fileManager.fileExists(atPath: path) {","            do {","                try fileManager.createDirectory(","                    atPath: path, ","                    withIntermediateDirectories: true, ","                    attributes: nil","                )","            } catch {","                print(\"Error: \\(error.localizedDescription)\")","            }","        }","    }","    path = path?.appendingPathComponent(file)","}"]},{"inlineContent":[{"type":"text","text":"After then, need to pass url path of logger file to peripheral init:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["do {","    try self.peripheral = Vigram.peripheral(","        peripheral,","        log: path","    )","} catch {","    print(\"Error: \\(error.localizedDescription)\")","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note: If you don’t pass url path to init, logger will not works"}]},{"inlineContent":[{"text":"The logger registered all activities and write its in file.","type":"text"}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigram.VigramSDK\/documentation\/VigramSDK\/UsePeripheralLogger"},"variants":[{"paths":["\/documentation\/vigramsdk\/useperipherallogger"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","references":{"doc://com.vigram.VigramSDK/documentation/VigramSDK/PeripheralLogger":{"url":"\/documentation\/vigramsdk\/peripherallogger","title":"PeripheralLogger","role":"symbol","abstract":[{"text":"The PeripheralLogger can be used to log a ","type":"text"},{"identifier":"doc:\/\/com.vigram.VigramSDK\/documentation\/VigramSDK\/Peripheral","isActive":true,"type":"reference"},{"text":"’s activity.","type":"text"}],"identifier":"doc:\/\/com.vigram.VigramSDK\/documentation\/VigramSDK\/PeripheralLogger","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"PeripheralLogger","kind":"identifier"}],"navigatorTitle":[{"text":"PeripheralLogger","kind":"identifier"}]},"doc://com.vigram.VigramSDK/documentation/VigramSDK/Peripheral":{"abstract":[{"type":"text","text":"Peripheral provides a write and receive interface to communicate with the viDoc device."}],"title":"Peripheral","url":"\/documentation\/vigramsdk\/peripheral","identifier":"doc:\/\/com.vigram.VigramSDK\/documentation\/VigramSDK\/Peripheral","kind":"symbol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Peripheral","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"Peripheral","kind":"identifier"}]},"doc://com.vigram.VigramSDK/documentation/VigramSDK":{"url":"\/documentation\/vigramsdk","abstract":[],"identifier":"doc:\/\/com.vigram.VigramSDK\/docu