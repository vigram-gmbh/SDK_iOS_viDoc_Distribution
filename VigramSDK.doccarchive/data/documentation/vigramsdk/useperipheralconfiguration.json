{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.vigram.VigramSDK\/documentation\/VigramSDK\/UsePeripheralConfiguration"},"sections":[],"kind":"article","metadata":{"roleHeading":"Article","title":"Use Peripheral Configuration","role":"article","modules":[{"name":"VigramSDK"}],"images":[{"identifier":"logo.png","type":"icon"}]},"hierarchy":{"paths":[["doc:\/\/com.vigram.VigramSDK\/documentation\/VigramSDK"]]},"primaryContentSections":[{"kind":"content","content":[{"text":"","anchor":"","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"If you need to disable some of the GNSS messages or change the rate of changing message or minimum elevation value use in navigation parameters, create a variable of type "},{"identifier":"doc:\/\/com.vigram.VigramSDK\/documentation\/VigramSDK\/PeripheralConfiguration","isActive":true,"type":"reference"},{"type":"text","text":" that includes the configuration data and receive this parameter to the peripheral initializer."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Example:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let peripheralConfiguration = PeripheralConfiguration(","    rateOfChangeMessages: .hertz1,","    glonassActivate: false",")"]},{"type":"paragraph","inlineContent":[{"text":"After then, need to pass configuration to peripheral init:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ If use logger","peripheral = Vigram.peripheral(","    peripheral,","    log: path,","    configuration: peripheralConfiguration",")","","\/\/ If not use logger","peripheral = Vigram.peripheral(","    peripheral,","    configuration: peripheralConfiguration",")","","\/\/ If not use configuration and logger","peripheral = Vigram.peripheral(peripheral)"]},{"type":"paragraph","inlineContent":[{"text":"Note: If this parameter is not recieved to the initializer, all parameters will be set by default.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Rate of changing message is set 7 hertz","rateOfChangeMessages: RateValue = .hertz7","","\/\/ Minimum elevation value using in navigation is set 10 degree","elevationValue: ElevationValue = .ang10,","","\/\/ All satellite constellation is active","glonassActivate = true","beidouActivate = true","galileoActivate = true","qzssActivate = true","sbassActivate = true","","\/\/ NAV-DOP and NAV-PVT Messages is active","navDOPActivate = true","navPVTActivate = true","","\/\/ Dynamic state mode","dynamicType = .pedestrian"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vigramsdk\/useperipheralconfiguration"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://com.vigram.VigramSDK/documentation/VigramSDK":{"url":"\/documentation\/vigramsdk","abstract":[],"identifier":"doc:\/\/com.vigram.VigramSDK\/documentation\/VigramSDK","role":"collection","title":"VigramSDK","images":[{"type":"icon","identifier":"logo.png"}],"type":"topic","kind":"symbol"},"doc://com.vigram.VigramSDK/documentation/VigramSDK/PeripheralConfiguration":{"identifier":"doc:\/\/com.vigram.VigramSDK\/documentation\/VigramSDK\/PeripheralConfiguration","abstract":[{"type":"text","text":"Initial configuration for peripheral"}],"type":"topic","url":"\/documentation\/vigramsdk\/peripheralconfiguration","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"PeripheralConfiguration"}],"title":"PeripheralConfiguration","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"PeripheralConfiguration","kind":"identifier"}],"kind":"symbol"},"logo.png":{"identifier":"logo.png","alt":"Vigram logo.","variants":[{"traits":["1x","light"],"url":"\/images\/logo.png"}],"type":"image"}}}